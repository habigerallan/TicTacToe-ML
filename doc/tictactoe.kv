#:kivy 2.2.1

<TicTacToeWidget>:
    BoxLayout:
        orientation: 'horizontal'
        
        BoxLayout:
            orientation: 'vertical'
            size_hint: None, None
            width: root.width * 2/3
            height: root.height
            padding: 3

            GridLayout:
                id: tictactoe_board
                rows: 3
                cols: 3

                BoxLayout:
                    id: cell_0

                    orientation: 'horizontal'
                    Button:
                        text: 'X'

                BoxLayout:
                    id: cell_1

                    orientation: 'horizontal'
                    Button:
                        text: 'O'

                BoxLayout:
                    id: cell_2

                    orientation: 'horizontal'
                    Button:
                        text: 'X'

                BoxLayout:
                    id: cell_3

                    orientation: 'horizontal'
                    Button:
                        text: 'X'

                BoxLayout:
                    id: cell_4

                    orientation: 'horizontal'
                    Button:
                        text: 'O'

                BoxLayout:
                    id: cell_5

                    orientation: 'horizontal'
                    Button:
                        text: 'X'

                BoxLayout:
                    id: cell_6

                    orientation: 'horizontal'
                    Button:
                        text: 'X'

                BoxLayout:
                    id: cell_7

                    orientation: 'horizontal'
                    Button:
                        text: 'O'

                BoxLayout:
                    id: cell_8

                    orientation: 'horizontal'
                    Button:
                        text: 'X'
        