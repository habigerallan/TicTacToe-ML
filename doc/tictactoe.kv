#:kivy 2.2.1

<TicTacToeWidget>:
    GridLayout:
        rows: 3
        cols: 3
        padding: 10
        spacing: 10
        width: self.minimum_width*15
        height: self.minimum_height*15

        Label:
            text: '1'

        Label:
            text: '2'

        Label:
            text: '3'

        Label:
            text: '4'

        Label:
            text: '5'

        Label:
            text: '6'

        Label:
            text: '7'

        Label:
            text: '8'

        Label:
            text: '9'