#:kivy 2.2.1

<TicTacToeWidget>:
    BoxLayout:
        orientation: 'horizontal'
        
        BoxLayout:
            orientation: 'vertical'
            size_hint: None, 1
            width: root.width * 2/3  # Set the width to 2/3 of the parent's width
            padding: 20  # Add padding for spacing

            GridLayout:
                id: tictactoe_board
                rows: 3
                cols: 1  # Use a single column for the grid

                # Define buttons for Tic-Tac-Toe cells here
                # For example, for the top-left cell:
                # BoxLayout:
                #     Button:
                #         text: 'X'
                #     Button:
                #         text: 'O'
                #     Button:
                #         text: 'X'

                # Temporary boxes for visualization
                BoxLayout:
                    orientation: 'horizontal'
                    Button:
                        text: 'X'
                    Button:
                        text: 'O'
                    Button:
                        text: 'X'

                BoxLayout:
                    orientation: 'horizontal'
                    Button:
                        text: 'O'
                    Button:
                        text: 'X'
                    Button:
                        text: 'O'

                BoxLayout:
                    orientation: 'horizontal'
                    Button:
                        text: 'X'
                    Button:
                        text: 'O'
                    Button:
                        text: 'X'

        BoxLayout:
            orientation: 'vertical'
            size_hint: None, 1
            width: root.width * 1/3  # Set the width to 1/3 of the parent's width
            padding: 20  # Add padding for spacing

            # Define menu icons or widgets here
            # For example, for a button:
            # Button:
            #     text: 'Menu Option 1'
            #     on_press: root.menu_option_1()

            # Another button example:
            # Button:
            #     text: 'Menu Option 2'
            #     on_press: root.menu_option_2()

            # Temporary boxes for visualization
            BoxLayout:
                Button:
                    text: 'Menu Option 1'

            BoxLayout:
                Button:
                    text: 'Menu Option 2'
